{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GTK App",
            "type": "shell",
            "command": "/usr/bin/gcc",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "`pkg-config", "--cflags", "--libs", "gtk+-3.0`"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}